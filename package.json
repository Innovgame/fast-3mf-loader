{
    "name": "fast-3mf-loader",
    "private": false,
    "description": "fast 3mf loader",
    "version": "0.0.7",
    "type": "module",
    "license": "MIT",
    "author": "rekor <innovgamejs@163.com>",
    "files": [
        "dist"
    ],
    "keywords": [
        "xml",
        "3mf",
        "three"
    ],
    "main": "./dist/fast-3mf-loader.umd.cjs",
    "module": "./dist/fast-3mf-loader.js",
    "types": "./dist/lib/main.d.ts",
    "exports": {
        ".": {
            "types": "./dist/lib/main.d.ts",
            "import": "./dist/fast-3mf-loader.js",
            "require": "./dist/fast-3mf-loader.umd.cjs"
        },
        "./*": "./*"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -p tsconfig.lib.json && vite build",
        "benchmark": "node scripts/benchmark.mjs",
        "benchmark:release": "FAST3MF_BENCHMARK_WARMUP_RUNS=2 FAST3MF_BENCHMARK_MEASURED_RUNS=7 FAST3MF_BENCHMARK_WORKERS=6 npm run benchmark",
        "check:demo": "tsc -p tsconfig.demo.json --noEmit",
        "check:test": "tsc -p tsconfig.test.json --noEmit",
        "test": "vitest run",
        "verify": "npm run check:demo && npm run check:test && npm test && npm run build",
        "release:check": "npm run verify && npm run benchmark:release && npm pack --dry-run"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/three": "^0.183.1",
        "jsdom": "^29.0.1",
        "three": "^0.183.2",
        "typescript": "~6.0.2",
        "vite": "^8.0.3",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "easysax": "^0.4.0",
        "fflate": "^0.8.2"
    },
    "directories": {
        "doc": "docs",
        "lib": "lib",
        "test": "test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Innovgame/fast-3mf-loader.git"
    },
    "bugs": {
        "url": "https://github.com/Innovgame/fast-3mf-loader/issues"
    },
    "homepage": "https://github.com/Innovgame/fast-3mf-loader#readme"
}
